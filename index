<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bank Statement Generator</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.23/jspdf.plugin.autotable.min.js"></script>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>Bank Statement Generator</h1>
        
        <div class="input-section">
            <input type="text" id="accName" placeholder="Account Name">
            <input type="number" id="balance" placeholder="Starting Balance">
            <input type="date" id="stmtDate">
        </div>

        <div class="transaction-form">
            <h3>Add Transaction</h3>
            <input type="date" id="transDate">
            <input type="text" id="transDesc" placeholder="Description (e.g. Rent, Deposit)">
            <input type="number" id="transAmount" placeholder="Amount (use - for spending)">
            <button onclick="addTransaction()">+ Add to List</button>
        </div>

        <div class="search-section">
            <input type="text" id="searchTerm" placeholder="🔍 Search list..." onkeyup="filterTransactions()">
        </div>

        <div id="balanceSummary">
            <span id="liveBalance">Closing Balance: $0.00</span>
        </div>

        <table id="transTable">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

        <div class="actions">
            <button class="download-btn" onclick="generatePDF()">Download PDF</button>
            <button class="csv-btn" onclick="downloadCSV()">Export CSV</button>
            <button class="print-btn" onclick="printStatement()">Print</button>
            <button class="clear-btn" onclick="clearForm()">Clear All</button>
        </div>
    </div>
    <script src="script.js"></script>
</body>
</html>
